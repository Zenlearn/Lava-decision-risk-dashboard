// Lava Decision Risk — Prisma Schema
// Provider: PostgreSQL (chosen for relational/hierarchical data model)
//
// Convention (from ZenLearn CLAUDE.md):
//   - Every foreign-key field has a corresponding @@index([field])
//   - Run: prisma generate && prisma db push
//
// Tables deferred to Phase 3 (NOT modelled here):
//   - training_assignments
//   - training_results
//
// No local `users` table — user identity comes from the shared JWT.
// Lava only stores role/org membership locally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// RBAC — Roles
// ─────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // Admin | MD | ServiceHead | RegionalHead | BUSM | ASM | Dealer | ASP | Trainer
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles   UserRole[]
}

// Binds a ZenLearn user (external JWT id) to a Lava role + optional org scope
model UserRole {
  id              String   @id @default(cuid())
  zenlearnUserId  String   // JWT `sub` / `id` from PathwaysBackend — no FK, external source of truth
  roleId          String
  dealerId        String?  // scoped to dealer, if applicable
  regionId        String?  // scoped to region, if applicable

  role            Role     @relation(fields: [roleId], references: [id])
  dealer          Dealer?  @relation(fields: [dealerId], references: [id])
  region          Region?  @relation(fields: [regionId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([zenlearnUserId])
  @@index([roleId])
  @@index([dealerId])
  @@index([regionId])
  @@unique([zenlearnUserId, roleId, dealerId, regionId])
}

// ─────────────────────────────────────────────────────────────
// Org Hierarchy — Region → Dealer → Service Centre (ASP) → Technician
// ─────────────────────────────────────────────────────────────

model Region {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String?

  dealers     Dealer[]
  userRoles   UserRole[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dealer {
  id          String   @id @default(cuid())
  name        String
  code        String?
  regionId    String

  region      Region           @relation(fields: [regionId], references: [id])
  serviceCentres ServiceCentre[]
  userRoles   UserRole[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([regionId])
}

model ServiceCentre {
  id          String   @id @default(cuid())
  name        String
  code        String?  // ASP code — primary cross-file join key (see fieldMap.config.ts)
  dealerId    String

  dealer      Dealer       @relation(fields: [dealerId], references: [id])
  technicians Technician[]
  workOrders  WorkOrder[]

  qcRecords          ComplianceQcRecord[]
  elsDoaRecords      ComplianceElsDoaRecord[]
  defectiveSpares    ComplianceDefectiveSpareRecord[]
  sahAppointments    ServiceAtHomeAppointment[]
  msmDailyRecords    MsmDailyRecord[]
  metricRollups      AspMetricRollup[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dealerId])
  @@index([code])
}

model Technician {
  id              String   @id @default(cuid())
  name            String
  employeeCode    String?
  serviceCentreId String

  serviceCentre   ServiceCentre @relation(fields: [serviceCentreId], references: [id])
  workOrders      WorkOrder[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([serviceCentreId])
}

// ─────────────────────────────────────────────────────────────
// Import — tracks each uploaded data file
// ─────────────────────────────────────────────────────────────

model MonthlyImport {
  id             String   @id @default(cuid())
  filename       String
  datasetType    DatasetType @default(MASTER_DATA)
  importedBy     String   // zenlearnUserId
  rowCount       Int
  rejectedCount  Int      @default(0)
  status         ImportStatus @default(PENDING)
  errorSummary   Json?    // Zod rejection details for failed rows

  workOrders     WorkOrder[]
  auditLogs      AuditLog[]

  qcRecords          ComplianceQcRecord[]
  elsDoaRecords      ComplianceElsDoaRecord[]
  defectiveSpares    ComplianceDefectiveSpareRecord[]
  sahAppointments    ServiceAtHomeAppointment[]
  msmDailyRecords    MsmDailyRecord[]

  importedAt     DateTime @default(now())
  completedAt    DateTime?

  @@index([importedBy])
  @@index([status])
}

// Which of the 6 Lava data files this import came from — determines which
// parser/field-map/persistence path the import pipeline takes.
enum DatasetType {
  MASTER_DATA
  COMPLIANCE_QC
  COMPLIANCE_ELS_DOA
  COMPLIANCE_DEFECTIVE_SPARE
  SERVICE_AT_HOME
  MSM_ACHIEVEMENT
  SPARE_PRICE_CATALOG
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// ─────────────────────────────────────────────────────────────
// Work Orders — one row per imported service record
// ─────────────────────────────────────────────────────────────

model WorkOrder {
  id              String   @id @default(cuid())
  importId        String
  serviceCentreId String
  technicianId    String?

  // Raw fields — stored as ingested (column names may evolve across imports)
  // Phase 1 will populate these from validated CSV rows.
  // NOTE: Column mapping lives in Phase 1 importService — NOT hardcoded here.
  rawData         Json     // full original row, for auditability
  month           String?  // derived month for fast dashboard querying (e.g., 'Feb')

  // Derived risk fields (populated by rule engine in Phase 1)
  skillScore      Float?
  auditScore      Float?
  processScore    Float?
  totalAnomalies  Int?

  import          MonthlyImport  @relation(fields: [importId], references: [id])
  serviceCentre   ServiceCentre  @relation(fields: [serviceCentreId], references: [id])
  technician      Technician?    @relation(fields: [technicianId], references: [id])
  riskFlags       RiskFlag[]

  createdAt       DateTime @default(now())

  @@index([importId])
  @@index([serviceCentreId])
  @@index([technicianId])
  @@index([totalAnomalies])
}

// ─────────────────────────────────────────────────────────────
// Risk Engine Output
// ─────────────────────────────────────────────────────────────

model RiskFlag {
  id            String   @id @default(cuid())
  workOrderId   String
  ruleKey       String   // e.g. "REPEAT_IMEI" | "SUSPICIOUS_PHONE" | "PROCESS_BREAKDOWN"
  severity      Severity
  evidence      Json     // rule-specific evidence payload
  recommendation String?

  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id])

  createdAt     DateTime @default(now())

  @@index([workOrderId])
  @@index([ruleKey])
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// NOTE: JudgementScore (per-row Skill/Audit/Process persistence) was removed.
// It duplicated what dashboard.service.ts recomputed live from WorkOrder.rawData
// on every request — neither approach scales past 100K+ rows across 6 datasets.
// AspMetricRollup (below) is the single source of truth for aggregate scoring now;
// row-level detail for evidence/hit-list drill-down stays in WorkOrder.rawData + RiskFlag.

// ─────────────────────────────────────────────────────────────
// Compliance datasets — audit sources for the Audit Score
// ─────────────────────────────────────────────────────────────

// IMEI QC sheet — SRN (Service Receipt Note) reconciliation: does the returned
// IMEI/Serial/Software match what was recorded on receipt.
model ComplianceQcRecord {
  id               String   @id @default(cuid())
  importId         String
  serviceCentreId  String
  workorderNumber  String
  complianceStatus String   // "Compliance" | "Non-Com" | "Non-com" (source data is inconsistent-cased)
  qcStatus         String?  // "Completed" | "Faulty" | "QC Not Done"
  month            String?
  rawData          Json

  import           MonthlyImport @relation(fields: [importId], references: [id])
  serviceCentre    ServiceCentre @relation(fields: [serviceCentreId], references: [id])

  createdAt        DateTime @default(now())

  @@index([importId])
  @@index([serviceCentreId])
  @@index([workorderNumber])
  @@index([month])
}

// ELS DOA REP sheet — was a claimed Dead-On-Arrival fault actually genuine.
model ComplianceElsDoaRecord {
  id                  String   @id @default(cuid())
  importId            String
  serviceCentreId     String
  workorderNumber     String
  complianceStatus    String   // "Compliance" | "Non-Compliance"
  nonComplianceReason String?
  value               Float?
  handsetCategory     String?  // "Smart phone" | "Feature phone"
  month               String?
  rawData             Json

  import              MonthlyImport @relation(fields: [importId], references: [id])
  serviceCentre       ServiceCentre @relation(fields: [serviceCentreId], references: [id])

  createdAt           DateTime @default(now())

  @@index([importId])
  @@index([serviceCentreId])
  @@index([workorderNumber])
  @@index([month])
}

// DEF(S+D) sheet — defective/damaged spare-parts returns (challan-based).
// partCode is a soft-reference to SparePriceCatalog.materialCode (~82% coverage,
// not enforced as a DB-level FK since the catalog doesn't cover every part).
model ComplianceDefectiveSpareRecord {
  id               String   @id @default(cuid())
  importId         String
  serviceCentreId  String
  challanNo        String?
  workOrderNumber  String?
  partCode         String?
  category         String?  // "SPARE-Defective" | "Fresh Faulty" | "Damaged"
  complianceStatus String   // "Compliance" | "Non-Compliance"
  amount           Float?
  debitQty         Int?
  month            String?
  rawData          Json

  import           MonthlyImport @relation(fields: [importId], references: [id])
  serviceCentre    ServiceCentre @relation(fields: [serviceCentreId], references: [id])

  createdAt        DateTime @default(now())

  @@index([importId])
  @@index([serviceCentreId])
  @@index([partCode])
  @@index([month])
}

// ─────────────────────────────────────────────────────────────
// Service at Home — home-visit appointment lifecycle (Process Score input)
// ─────────────────────────────────────────────────────────────

model ServiceAtHomeAppointment {
  id                String    @id @default(cuid())
  importId          String
  serviceCentreId   String
  appointmentId     String
  workOrderNumber   String?   // different WO series from Master Data — ~65% overlap, join is best-effort
  appointmentStatus String?   // "Closed" | "In Process" | "Reject/Cancel" | "Request For Cancel" | ...
  appointmentDate   DateTime?
  cancelReason      String?
  month             String?
  rawData           Json

  import            MonthlyImport @relation(fields: [importId], references: [id])
  serviceCentre     ServiceCentre @relation(fields: [serviceCentreId], references: [id])

  createdAt         DateTime @default(now())

  @@index([importId])
  @@index([serviceCentreId])
  @@index([workOrderNumber])
  @@index([month])
}

// ─────────────────────────────────────────────────────────────
// MSM Achievement — daily ASP deposit/stock compliance (financial exposure,
// Process Score input). Source sheet is a pivot (one column per calendar day) —
// melted into one row per (ASP, day) at import time.
// ─────────────────────────────────────────────────────────────

model MsmDailyRecord {
  id               String    @id @default(cuid())
  importId         String
  serviceCentreId  String
  date             DateTime
  complianceStatus String?   // "Compliance" | "Non Compliance" | null (non-working day, source uses "-")
  balanceValue     Float?
  msmTarget        Float?
  month            String?

  import           MonthlyImport @relation(fields: [importId], references: [id])
  serviceCentre    ServiceCentre @relation(fields: [serviceCentreId], references: [id])

  createdAt        DateTime @default(now())

  @@unique([serviceCentreId, date])
  @@index([importId])
  @@index([serviceCentreId])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// ZPRP Spare Price Catalog — reference table, no serviceCentre link.
// Re-upserted (not appended) on each import since it's a point-in-time price list.
// ─────────────────────────────────────────────────────────────

model SparePriceCatalog {
  id                  String    @id @default(cuid())
  materialCode        String    @unique
  materialDescription String?
  basicPrice          Float?
  distributorPrice    Float?
  taxRate             Float?
  validFrom           DateTime?
  validTo             DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────
// ASP Metric Rollup — the single source of truth for dashboard reads.
// One row per (ServiceCentre, month), computed by the rule engine after each
// import completes. Replaces per-request live recomputation from WorkOrder.rawData.
// ─────────────────────────────────────────────────────────────

model AspMetricRollup {
  id              String   @id @default(cuid())
  serviceCentreId String
  month           String

  // 5 fixed Executive Dashboard tiles — definitions unchanged from the current UI
  ftfr            Float?   // First-time fix rate (%)
  csat            Float?   // Customer satisfaction (%) — nullable: dormant, no NPS/VOC data in this drop
  mttr            Float?   // Mean time to repair (days)
  diag            Float?   // Diagnostic accuracy (%)
  leak            Float?   // Estimated monthly leakage exposure (₹)

  // 3 category scores (0-100, baseline 100 clipped at 0 — same convention as before)
  skillScore      Float?
  auditScore      Float?
  processScore    Float?

  // Deep-dive child metrics per category — kept as JSON since the exact child-metric
  // set will keep evolving as signals are validated against real data; see rules/engine.ts
  // for the current shape of skill/audit/process child breakdowns.
  childMetrics    Json?

  serviceCentre   ServiceCentre @relation(fields: [serviceCentreId], references: [id])

  computedAt      DateTime @default(now())

  @@unique([serviceCentreId, month])
  @@index([serviceCentreId])
  @@index([month])
}

// ─────────────────────────────────────────────────────────────
// Dashboard Cache — stores pre-computed dashboard blobs per role scope
// ─────────────────────────────────────────────────────────────

model DashboardCache {
  id          String   @id @default(cuid())
  cacheKey    String   @unique // e.g. "executive" | "region:clxxx" | "dealer:clyyy"
  payload     Json
  importId    String?  // null means stale/manually busted

  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// Audit Log — server-side action log (not user-facing yet in Phase 0)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  zenlearnUserId String
  action         String   // e.g. "IMPORT_UPLOAD" | "DASHBOARD_VIEW" | "AUDIT_EXPORT"
  resourceType   String?
  resourceId     String?
  importId       String?
  metadata       Json?
  ipAddress      String?

  import         MonthlyImport? @relation(fields: [importId], references: [id])

  createdAt      DateTime @default(now())

  @@index([zenlearnUserId])
  @@index([action])
  @@index([importId])
  @@index([createdAt])
}
