# Lava Decision Risk — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3010

# ── Auth (must match PathwaysBackend's JWT_SECRET exactly) ──────────────────
# The same JWT issued by ZenLearn's login endpoint is accepted here.
JWT_SECRET=your-shared-jwt-secret-here

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# docker-compose local dev: postgresql://postgres:postgres@localhost:5432/lava
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lava

# ── Redis ────────────────────────────────────────────────────────────────────
# docker-compose local dev: localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3011,http://localhost:3000
